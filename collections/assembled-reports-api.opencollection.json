{
  "opencollection": "1.0.0",
  "info": {
    "name": "Assembled Reports API",
    "version": "2026-05-24"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Reports",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled Start Report",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.assembledhq.com/v0/reports/:reportType",
            "params": [
              {
                "name": "reportType",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Kick off generation of a structured report."
        },
        {
          "info": {
            "name": "Assembled Get Report",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.assembledhq.com/v0/reports/:reportID",
            "params": [
              {
                "name": "reportID",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve a generated report by ID. Poll until status is `complete`."
        }
      ]
    }
  ],
  "bundled": true
}
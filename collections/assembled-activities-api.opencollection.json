{
  "opencollection": "1.0.0",
  "info": {
    "name": "Assembled Activities API",
    "version": "2026-05-24"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Activities",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled List Activities",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.assembledhq.com/v0/activities",
            "headers": [
              {
                "name": "API-Version",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "start_time",
                "value": "",
                "type": "query"
              },
              {
                "name": "end_time",
                "value": "",
                "type": "query"
              },
              {
                "name": "agent_ids",
                "value": "",
                "type": "query"
              },
              {
                "name": "queue_ids",
                "value": "",
                "type": "query"
              },
              {
                "name": "activity_type_id",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List activities for a time window, optionally filtered by agent, queue, site, or type."
        },
        {
          "info": {
            "name": "Assembled Create Activity",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.assembledhq.com/v0/activities",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a single activity."
        },
        {
          "info": {
            "name": "Assembled Delete Activities",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.assembledhq.com/v0/activities",
            "params": [
              {
                "name": "ids",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Soft-delete one or more activities by ID."
        },
        {
          "info": {
            "name": "Assembled Bulk Create Activities",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.assembledhq.com/v0/activities/bulk",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create many activities in a single request."
        }
      ]
    },
    {
      "info": {
        "name": "Activity Types",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled List Activity Types",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.assembledhq.com/v0/activity_types"
          },
          "docs": "List activity types defined in your organization."
        },
        {
          "info": {
            "name": "Assembled Create Activity Type",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.assembledhq.com/v0/activity_types",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Define a new activity type (name and colour)."
        },
        {
          "info": {
            "name": "Assembled Delete Activity Type",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.assembledhq.com/v0/activity_types/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete an activity type."
        }
      ]
    },
    {
      "info": {
        "name": "Event Changes",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled List Event Changes",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.assembledhq.com/v0/event_changes",
            "params": [
              {
                "name": "start_time",
                "value": "",
                "type": "query"
              },
              {
                "name": "end_time",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve the audit trail of schedule modifications across activities."
        }
      ]
    }
  ],
  "bundled": true
}
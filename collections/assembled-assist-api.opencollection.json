{
  "opencollection": "1.0.0",
  "info": {
    "name": "Assembled Assist API",
    "version": "2026-05-24"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Assist Responses",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled Submit Assist Response",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.assembledhq.com/v0/assist/responses",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Submit a chat response generated by an Assembled AI Agent."
        },
        {
          "info": {
            "name": "Assembled Get Assist Response Handoff",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.assembledhq.com/v0/assist/responses/handoff",
            "params": [
              {
                "name": "conversation_id",
                "value": "",
                "type": "query"
              },
              {
                "name": "since",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Retrieve handoff payloads for responses that escalated to a human agent."
        }
      ]
    },
    {
      "info": {
        "name": "Assist Conversations",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled List Assist Conversations",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.assembledhq.com/v0/assist/conversations",
            "params": [
              {
                "name": "start_time",
                "value": "",
                "type": "query"
              },
              {
                "name": "end_time",
                "value": "",
                "type": "query"
              },
              {
                "name": "status",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List AI-assisted conversations."
        },
        {
          "info": {
            "name": "Assembled Get Assist Conversation Handoff",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.assembledhq.com/v0/assist/conversations/:id/handoff",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve the handoff payload for a single AI-assisted conversation."
        }
      ]
    },
    {
      "info": {
        "name": "Assist Articles",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled Create Assist Article",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.assembledhq.com/v0/assist/articles",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a knowledge article that AI Agents can reference."
        },
        {
          "info": {
            "name": "Assembled Update Assist Article",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://api.assembledhq.com/v0/assist/articles/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Assembled Update Assist Article"
        },
        {
          "info": {
            "name": "Assembled Delete Assist Article",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.assembledhq.com/v0/assist/articles/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Assembled Delete Assist Article"
        }
      ]
    },
    {
      "info": {
        "name": "Assist Replies",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Assembled Submit Assist Reply (Beta)",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.assembledhq.com/v0/assist/replies",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Beta endpoint for posting AI-generated replies directly. Subject to change."
        }
      ]
    }
  ],
  "bundled": true
}
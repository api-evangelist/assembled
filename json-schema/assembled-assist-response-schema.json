{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/assembled/refs/heads/main/json-schema/assembled-assist-response-schema.json",
  "title": "AssembledAssistResponse",
  "description": "An AI-generated response produced by an Assembled AI Agent and posted via the Assist API.",
  "type": "object",
  "required": ["id", "conversation_id", "body"],
  "properties": {
    "id": { "type": "string" },
    "conversation_id": { "type": "string" },
    "channel": { "type": "string", "enum": ["chat", "email", "sms", "voice"] },
    "body": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "model": { "type": "string" },
    "cited_article_ids": { "type": "array", "items": { "type": "string" } },
    "metadata": { "type": "object", "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
